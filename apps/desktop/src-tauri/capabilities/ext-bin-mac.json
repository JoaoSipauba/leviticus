{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "ext-bin-mac",
  "description": "yt-dlp e ffmpeg baixados em runtime pra $APPLOCALDATA/bin (macOS e Linux)",
  "windows": ["main"],
  "platforms": ["macOS", "linux"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "yt-dlp", "cmd": "$APPLOCALDATA/bin/yt-dlp", "args": true },
        { "name": "ffmpeg", "cmd": "$APPLOCALDATA/bin/ffmpeg", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "yt-dlp", "cmd": "$APPLOCALDATA/bin/yt-dlp", "args": true },
        { "name": "ffmpeg", "cmd": "$APPLOCALDATA/bin/ffmpeg", "args": true }
      ]
    }
  ]
}
